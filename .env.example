# ============================================================
# ACUBE V2 — Environment Variables (EXAMPLE)
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# Values below are placeholders; each is wired in its milestone.
# ============================================================

# --- Site ---
# Production domain (e.g. https://your-domain.ae). Leave empty locally;
# the app falls back to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# --- Build ---
# Set to "true" for the Hostinger (Linux) production build to emit a
# standalone server bundle. Leave empty locally on Windows (symlink perms).
BUILD_STANDALONE=

# --- Email / Contact form (Milestone 14) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
CONTACT_TO_EMAIL=

# --- Google Maps (Contact section, Milestone 14) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Analytics (Milestone 16/17) ---
NEXT_PUBLIC_ANALYTICS_ID=
