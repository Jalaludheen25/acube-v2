# Normalize line endings to LF in the repo (Windows dev → Linux deploy).
* text=auto eol=lf

# Treat binary assets as binary (no EOL conversion, no diff).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.avif  binary
*.ico   binary
*.gif   binary
*.mp4   binary
*.webm  binary
*.glb   binary
*.gltf  binary
*.hdr   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
